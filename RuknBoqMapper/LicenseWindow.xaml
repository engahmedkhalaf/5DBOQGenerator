<Window x:Class="RuknBoqMapper.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Manager — RUKNBIM" 
        Height="475" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        FontFamily="Segoe UI"
        FontSize="11"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Full-Width Premium Blue Button Style -->
        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content (Status + Form) -->
            <RowDefinition Height="Auto"/>   <!-- Footer (Support + Close) -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="RUKNBIM 5D BOQ MANAGER" Foreground="White" FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBlock Text="License &amp; Activation Center" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0"/>
                <Border BorderBrush="#1E293B" BorderThickness="0,0,0,1" Margin="0,12,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Click="LogoButton_Click" ToolTip="Visit ruknbim.com"
                    VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" BorderBrush="#334155" BorderThickness="1" Padding="8,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="RUKN" Foreground="#3B82F6" FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                <TextBlock Text="BIM" Foreground="White" FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Status Card -->
                <RowDefinition Height="*"/>    <!-- Form Fields / Sign Out -->
            </Grid.RowDefinitions>

            <!-- Status Card -->
            <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="● License Status" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                    
                    <DockPanel LastChildFill="True" Margin="0,0,0,6">
                        <TextBlock Text="Status:" Foreground="#94A3B8" FontSize="11" Width="70" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="StatusTextVal" Text="Not Activated" Foreground="#F87171" FontSize="12" FontWeight="Bold"/>
                    </DockPanel>

                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                        <TextBlock Text="Details:" Foreground="#94A3B8" FontSize="11" Width="70" DockPanel.Dock="Left" VerticalAlignment="Top"/>
                        <TextBlock x:Name="DetailsTextVal" Text="No active license found. Enter your email and activation code below." Foreground="#E2E8F0" FontSize="11" TextWrapping="Wrap"/>
                    </DockPanel>

                    <DockPanel LastChildFill="True">
                        <Button x:Name="PingButton" Content="Test Connection" Click="PingButton_Click"
                                DockPanel.Dock="Left" Height="18" Width="90" FontSize="9" FontWeight="Normal"
                                Background="#0F172A" Foreground="#64748B" BorderBrush="#1E293B" BorderThickness="1"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#1E293B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock x:Name="PingResultText" Foreground="#64748B" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Input Fields Form or Deactivation Form -->
            <Grid Grid.Row="1">
                <!-- Activation Form (Visible when NOT activated) -->
                <StackPanel x:Name="ActivationFormPanel" Visibility="Visible">
                    <!-- Email field -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Registered Email" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBox x:Name="EmailTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                 Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Foreground="White" CaretBrush="White"/>
                    </StackPanel>

                    <!-- Code field -->
                    <StackPanel Margin="0,0,0,16">
                        <DockPanel LastChildFill="False" Margin="0,0,0,4">
                            <TextBlock Text="Activation Code" FontSize="11" Foreground="#94A3B8" DockPanel.Dock="Left"/>
                            <TextBlock DockPanel.Dock="Right" FontSize="11">
                                <Hyperlink Click="RequestCode_Click" Foreground="#3B82F6" TextDecorations="{x:Null}">Request Activation Code</Hyperlink>
                            </TextBlock>
                        </DockPanel>
                        <TextBox x:Name="CodeTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                 Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Foreground="White" CaretBrush="White"/>
                    </StackPanel>

                    <!-- Error / Info Feedback Label -->
                    <TextBlock x:Name="StatusLabel" Foreground="#EF4444" FontSize="11" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- Activate Button -->
                    <Button Content="Activate License" Click="ActivateButton_Click" Style="{StaticResource PremiumButton}"/>
                </StackPanel>

                <!-- Deactivation Panel (Visible when activated) -->
                <StackPanel x:Name="DeactivationPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="To clean up the registration or log in with another account, you can sign out." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" TextAlignment="Center"/>
                    <Button x:Name="BtnSignOut" Content="Sign Out / Deactivate" Click="SignOutButton_Click" Style="{StaticResource SecondaryButton}" Height="34" Width="180" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock FontSize="10" Foreground="#64748B">
                    <Run Text="Support: "/>
                    <Hyperlink NavigateUri="mailto:support@ruknbim.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#3B82F6">support@ruknbim.com</Hyperlink>
                </TextBlock>
            </StackPanel>
            <Button Content="Close" Click="CloseButton_Click" Style="{StaticResource SecondaryButton}" Grid.Column="1" Width="80"/>
        </Grid>
    </Grid>
</Window>
