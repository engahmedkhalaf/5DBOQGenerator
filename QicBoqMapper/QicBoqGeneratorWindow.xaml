<Window x:Class="QicBoqMapper.QicBoqGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QIC Tools – QIC 5D BOQ Code Generator" 
        Height="780" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Inter, Roboto"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <Style x:Key="ModernScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- File Operations -->
            <RowDefinition Height="Auto"/> <!-- Settings -->
            <RowDefinition Height="*"/>    <!-- Categories -->
            <RowDefinition Height="Auto"/> <!-- Action Buttons -->
            <RowDefinition Height="Auto"/> <!-- Status Panel -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0F172A" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="QIC 5D BOQ Code Generator" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Link Excel BOQ mapping data to Revit elements with matching priorities and full audit reporting" Foreground="#94A3B8" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- File Operations Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Excel Mapping Operations" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding ExcelFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Grid.Column="0" 
                             Height="32" 
                             VerticalContentAlignment="Center" 
                             Padding="8,0"
                             BorderBrush="#CBD5E1"
                             Foreground="#334155"/>
                    <Button Command="{Binding BrowseFileCommand}" 
                            Content="Browse..." 
                            Grid.Column="1" 
                            Width="80" 
                            Height="32" 
                            Margin="8,0,0,0"
                            Background="#F1F5F9"
                            BorderBrush="#CBD5E1"
                            Foreground="#475569"/>
                    <Button Command="{Binding LoadExcelCommand}" 
                            Content="Import Mapping" 
                            Grid.Column="2" 
                            Width="110" 
                            Height="32" 
                            Margin="8,0,0,0"
                            Background="#2563EB"
                            BorderBrush="#2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"/>
                    <Button Command="{Binding ExportElementsCommand}" 
                            Content="Export Elements" 
                            Grid.Column="3" 
                            Width="120" 
                            Height="32" 
                            Margin="8,0,0,0"
                            Background="#0EA5E9"
                            BorderBrush="#0EA5E9"
                            Foreground="White"
                            FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Configuration Settings Card -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Selection Scope -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Selection Scope" FontWeight="SemiBold" FontSize="12" Foreground="#475569" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding SelectionModes}" SelectedItem="{Binding SelectionMode}" Height="30" VerticalContentAlignment="Center"/>
                    <CheckBox IsChecked="{Binding CaseInsensitive}" Content="Case-Insensitive Match" Margin="0,8,0,0" Foreground="#64748B" FontSize="11"/>
                </StackPanel>

                <!-- Matching Method -->
                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                    <TextBlock Text="Matching Priority Method" FontWeight="SemiBold" FontSize="12" Foreground="#475569" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding MatchingMethods}" SelectedItem="{Binding MatchingMethod}" Height="30" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Code Separator -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="BOQ Code Separator" FontWeight="SemiBold" FontSize="12" Foreground="#475569" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding SeparatorStyles}" SelectedItem="{Binding SeparatorStyle}" Height="30" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Target Revit Categories Card -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Filter Revit Categories" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="All" Click="SelectAllCategories_Click" Width="50" Height="24" Background="#F1F5F9" BorderBrush="#CBD5E1" Foreground="#475569" FontSize="11"/>
                        <Button Content="None" Click="SelectNoCategories_Click" Width="50" Height="24" Margin="5,0,0,0" Background="#F1F5F9" BorderBrush="#CBD5E1" Foreground="#475569" FontSize="11"/>
                    </StackPanel>
                </Grid>
                
                <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}">
                    <ItemsControl ItemsSource="{Binding CategoryItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Name}" Margin="0,5,15,5" Width="190" Foreground="#334155"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Action Buttons Card -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding ValidateCommand}" Content="Validate Mapping" Grid.Column="0" Height="36" Margin="0,0,5,0" Background="#1E293B" BorderBrush="#1E293B" Foreground="White" FontWeight="SemiBold"/>
                <Button Command="{Binding GenerateCommand}" Content="Generate 5D Codes" Grid.Column="1" Height="36" Margin="5,0,5,0" Background="#16A34A" BorderBrush="#16A34A" Foreground="White" FontWeight="SemiBold"/>
                <Button Command="{Binding ExportReportCommand}" Content="Export Audit Report" Grid.Column="2" Height="36" Margin="5,0,0,0" Background="#EA580C" BorderBrush="#EA580C" Foreground="White" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Status Panel -->
        <Border Grid.Row="5" Background="#0F172A" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Stats Row -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LoadedRecordsCount}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="BOQ Mapping" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ProcessedElementsCount}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Elements" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MatchedTypesCount}" Foreground="#10B981" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Matched" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding WarningCount}" Foreground="#F59E0B" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Warnings" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ErrorCount}" Foreground="#EF4444" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Errors/Unmapped" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <ProgressBar Grid.Row="1" Height="8" Value="{Binding ProgressValue}" Margin="0,0,0,8" Background="#334155" Foreground="#3B82F6" BorderThickness="0"/>
                
                <TextBlock Grid.Row="2" Text="{Binding StatusText}" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
