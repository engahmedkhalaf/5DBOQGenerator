<Window x:Class="QicBoqMapper.QicBoqGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QIC Tools – 5D BOQ Manager" 
        Height="500" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Background="#0F172A"
        FontFamily="Segoe UI, Inter, Roboto"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Modern Custom Button Style -->
        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#0F172A"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="BorderBrush" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio Button Modern Style -->
        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- License Card -->
            <RowDefinition Height="Auto"/> <!-- Scope Selection -->
            <RowDefinition Height="*"/>    <!-- Primary Actions -->
            <RowDefinition Height="Auto"/> <!-- Progress & Status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="QIC 5D BOQ MANAGER" Foreground="#3B82F6" FontSize="11" FontWeight="Bold"/>
                <TextBlock Text="Model Metadata Linker" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- License Card -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Activate License" FontWeight="SemiBold" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LicenseStatus}" FontSize="11" Foreground="#10B981" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" 
                             Grid.Column="0" 
                             Height="32" 
                             VerticalContentAlignment="Center" 
                             Padding="8,0"
                             Background="#0F172A"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="White"
                             CaretBrush="White"/>
                    <Button Command="{Binding ActivateLicenseCommand}" 
                            Style="{StaticResource PremiumButton}"
                            Content="Activate" 
                            Grid.Column="1" 
                            Width="80" 
                            Height="32" 
                            Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Scope Selection Card -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Selection Scope" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Current Selection" 
                                 IsChecked="{Binding IsCurrentSelectionSelected}" 
                                 Style="{StaticResource ModernRadioButton}"/>
                    <RadioButton Content="Active View" 
                                 IsChecked="{Binding IsActiveViewSelected}" 
                                 Style="{StaticResource ModernRadioButton}"/>
                    <RadioButton Content="Whole Model" 
                                 IsChecked="{Binding IsWholeModelSelected}" 
                                 Style="{StaticResource ModernRadioButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Primary Action Buttons Card -->
        <Border Grid.Row="3" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Command="{Binding ExportElementsCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Export Elements to Excel" 
                        Grid.Row="0" 
                        Margin="0,0,0,8"/>
                
                <Button Command="{Binding ImportExcelCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Import Excel Parameters" 
                        Grid.Row="1" 
                        Margin="0,0,0,8"/>
                
                <Button Command="{Binding GenerateCommand}" 
                        Style="{StaticResource PremiumButton}" 
                        Content="Generate 5D BOQ Codes" 
                        Grid.Row="2"/>
            </Grid>
        </Border>

        <!-- Progress & Status Panel -->
        <Border Grid.Row="4" Background="#1E293B" CornerRadius="8" Padding="12" BorderBrush="#334155" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{Binding StatusText}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Matched: " Foreground="#94A3B8" FontSize="11"/>
                        <TextBlock Text="{Binding MatchedTypesCount}" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
                <ProgressBar Height="6" Value="{Binding ProgressValue}" Background="#0F172A" Foreground="#3B82F6" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
